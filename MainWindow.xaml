<Window x:Class="PcStatsMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:PcStatsMonitor.Controls"
        xmlns:local="clr-namespace:PcStatsMonitor"
        Title="BYLD Core" 
        Height="{Binding Theme.WindowHeight, FallbackValue=854}" 
        Width="{Binding Theme.WindowWidth, FallbackValue=480}"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="{Binding Theme.BackgroundColor, FallbackValue=#060606}"
        Topmost="True"
        ShowInTaskbar="False"
        Icon="Assets/byld-icon.png">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:DictionaryValueConverter x:Key="DictValConv" />
    </Window.Resources>

    <!-- 9:16 Scale Transform so it perfectly fits regardless of Window Width/Height -->
    <Viewbox Stretch="Uniform">
        <Grid Width="480" Height="854">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*"/>
                <ColumnDefinition Width="5*"/>
            </Grid.ColumnDefinitions>

            <!-- Custom Background Image Container (Z-Index behind Gauges) -->
            <Image Source="{Binding Theme.BackgroundImagePath}" 
                   Opacity="{Binding Theme.BackgroundOpacity}" 
                   Stretch="UniformToFill" 
                   Grid.ColumnSpan="2" />

            <!-- Container for everything Gauges-related -->
            <Grid x:Name="GaugesContainer" Grid.ColumnSpan="2">
                <!-- Top Logo Area. The client image has the logo ABOVE the gauges. -->
                <Image Source="{Binding Theme.LogoPath}" Height="160" Margin="20,-20,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" Stretch="Uniform" />

                <!-- Screen 1: Gauges. Replaced rigid StackPanel with a dynamic ItemsControl -->
                <Viewbox MaxHeight="620" VerticalAlignment="Top" Margin="0,100,0,0" StretchDirection="DownOnly">
                    <ItemsControl ItemsSource="{Binding Theme.ActiveMonitorsOrder}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ContentControl Content="{Binding}" RenderTransformOrigin="0.5,0.5">
                                    <ContentControl.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform>
                                                <ScaleTransform.ScaleX>
                                                    <MultiBinding Converter="{StaticResource DictValConv}" ConverterParameter="1.0">
                                                        <Binding Path="DataContext.Theme.GaugeScales" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                        <Binding />
                                                    </MultiBinding>
                                                </ScaleTransform.ScaleX>
                                                <ScaleTransform.ScaleY>
                                                    <MultiBinding Converter="{StaticResource DictValConv}" ConverterParameter="1.0">
                                                        <Binding Path="DataContext.Theme.GaugeScales" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                        <Binding />
                                                    </MultiBinding>
                                                </ScaleTransform.ScaleY>
                                            </ScaleTransform>
                                            <TranslateTransform>
                                                <TranslateTransform.X>
                                                    <MultiBinding Converter="{StaticResource DictValConv}" ConverterParameter="0.0">
                                                        <Binding Path="DataContext.Theme.GaugeOffsetsX" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                        <Binding />
                                                    </MultiBinding>
                                                </TranslateTransform.X>
                                                <TranslateTransform.Y>
                                                    <MultiBinding Converter="{StaticResource DictValConv}" ConverterParameter="0.0">
                                                        <Binding Path="DataContext.Theme.GaugeOffsetsY" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                        <Binding />
                                                    </MultiBinding>
                                                </TranslateTransform.Y>
                                            </TranslateTransform>
                                        </TransformGroup>
                                    </ContentControl.RenderTransform>
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Style.Triggers>
                                                <!-- GPU GAUGE -->
                                                <DataTrigger Binding="{Binding}" Value="GPU">
                                                    <Setter Property="ContentTemplate">
                                                        <Setter.Value>
                                                            <DataTemplate>
                                                                <controls:DualCircularGauge 
                                                                    Visibility="{Binding DataContext.Theme.IsGpuEnabled, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BoolToVis}}"
                                                                    Width="192" Height="192" Margin="0,0,0,20"
                                                                    CenterLabelString="GPU TEMP" 
                                                                    CenterTextString="{Binding DataContext.Metrics.GpuTemp, RelativeSource={RelativeSource AncestorType=ItemsControl}, StringFormat={}{0:0}°C}" 
                                                                    LeftValue="{Binding DataContext.Metrics.GpuTemp, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    RightLabelTextString="GPU LOAD"
                                                                    RightValueTextString="{Binding DataContext.Metrics.GpuLoad, RelativeSource={RelativeSource AncestorType=ItemsControl}, StringFormat={}{0:0}%}"
                                                                    RightValue="{Binding DataContext.Metrics.GpuLoad, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                                            </DataTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <!-- CPU GAUGE -->
                                                <DataTrigger Binding="{Binding}" Value="CPU">
                                                    <Setter Property="ContentTemplate">
                                                        <Setter.Value>
                                                            <DataTemplate>
                                                                <controls:DualCircularGauge 
                                                                    Visibility="{Binding DataContext.Theme.IsCpuEnabled, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BoolToVis}}"
                                                                    Width="192" Height="192" Margin="0,0,0,20"
                                                                    CenterLabelString="CPU TEMP" 
                                                                    CenterTextString="{Binding DataContext.Metrics.CpuTemp, RelativeSource={RelativeSource AncestorType=ItemsControl}, StringFormat={}{0:0}°C}" 
                                                                    LeftValue="{Binding DataContext.Metrics.CpuTemp, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    RightLabelTextString="CPU LOAD"
                                                                    RightValueTextString="{Binding DataContext.Metrics.CpuLoad, RelativeSource={RelativeSource AncestorType=ItemsControl}, StringFormat={}{0:0}%}"
                                                                    RightValue="{Binding DataContext.Metrics.CpuLoad, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                                            </DataTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <!-- MEMORY GAUGE -->
                                                <DataTrigger Binding="{Binding}" Value="RAM">
                                                    <Setter Property="ContentTemplate">
                                                        <Setter.Value>
                                                            <DataTemplate>
                                                                <controls:DualCircularGauge 
                                                                    Visibility="{Binding DataContext.Theme.IsMemoryEnabled, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BoolToVis}}"
                                                                    Width="192" Height="192" Margin="0,0,0,20"
                                                                    CenterLabelString="RAM LOAD" 
                                                                    CenterTextString="{Binding DataContext.Metrics.RamLoad, RelativeSource={RelativeSource AncestorType=ItemsControl}, StringFormat={}{0:0}%}" 
                                                                    LeftValue="{Binding DataContext.Metrics.RamLoad, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    RightLabelTextString="DRIVE C: LOAD"
                                                                    RightValueTextString="{Binding DataContext.Metrics.Drives[0].Load, RelativeSource={RelativeSource AncestorType=ItemsControl}, FallbackValue=0, StringFormat={}{0:0}%}" 
                                                                    RightValue="{Binding DataContext.Metrics.Drives[0].Load, RelativeSource={RelativeSource AncestorType=ItemsControl}, FallbackValue=0}" />
                                                            </DataTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <!-- MOTHERBOARD GAUGE -->
                                                <DataTrigger Binding="{Binding}" Value="MOTHERBOARD">
                                                    <Setter Property="ContentTemplate">
                                                        <Setter.Value>
                                                            <DataTemplate>
                                                                <controls:DualCircularGauge 
                                                                    Visibility="{Binding DataContext.Theme.IsMotherboardEnabled, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BoolToVis}}"
                                                                    Width="192" Height="192" Margin="0,0,0,20"
                                                                    CenterLabelString="VRM TEMP" 
                                                                    CenterTextString="{Binding DataContext.Metrics.MotherboardTemp, RelativeSource={RelativeSource AncestorType=ItemsControl}, StringFormat={}{0:0}°C}" 
                                                                    LeftValue="{Binding DataContext.Metrics.MotherboardTemp, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    RightLabelTextString="FAN SPEED"
                                                                    RightValueTextString="{Binding DataContext.Metrics.FanSpeed, RelativeSource={RelativeSource AncestorType=ItemsControl}, StringFormat={}{0:0}RPM}" 
                                                                    RightValue="0" />
                                                            </DataTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <!-- NETWORK CARD -->
                                                <DataTrigger Binding="{Binding}" Value="NETWORK">
                                                    <Setter Property="ContentTemplate">
                                                        <Setter.Value>
                                                            <DataTemplate>
                                                                <Border Width="192" Height="60" Margin="0,0,0,20" CornerRadius="12" Background="#11FFFFFF" Visibility="{Binding DataContext.Theme.IsNetworkEnabled, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BoolToVis}}">
                                                                    <Grid Margin="15,0">
                                                                        <TextBlock Text="NETWORK UP/DOWN" Foreground="{Binding DataContext.Theme.ForegroundColor, RelativeSource={RelativeSource AncestorType=ItemsControl}, FallbackValue='#DCDCDC'}" Opacity="0.8" FontSize="11" FontWeight="Bold" VerticalAlignment="Top" Margin="0,8,0,0"/>
                                                                        <TextBlock Text="{Binding DataContext.Metrics.NetworkDown, RelativeSource={RelativeSource AncestorType=ItemsControl}, StringFormat=DL: {0:0.0} B/s}" Foreground="{Binding DataContext.Theme.ForegroundColor, RelativeSource={RelativeSource AncestorType=ItemsControl}, FallbackValue='#FFFFFF'}" FontSize="14" FontWeight="Bold" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                                                                        <TextBlock Text="{Binding DataContext.Metrics.NetworkUp, RelativeSource={RelativeSource AncestorType=ItemsControl}, StringFormat=UL: {0:0.0} B/s}" Foreground="{Binding DataContext.Theme.ForegroundColor, RelativeSource={RelativeSource AncestorType=ItemsControl}, FallbackValue='#FFFFFF'}" FontSize="14" FontWeight="Bold" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,0,10"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                </ContentControl>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Viewbox>



                <!-- Bottom text metrics -->
                <Grid VerticalAlignment="Bottom" Margin="30,0,30,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Metrics.CpuClock, StringFormat=CPU CLOCK: {0:0} MHz}" Foreground="{Binding Theme.ForegroundColor, FallbackValue=#FFFFFF}" Opacity="0.85" FontSize="13" FontWeight="Bold" HorizontalAlignment="Left" FontFamily="{Binding Theme.FontFamily, FallbackValue='Segoe UI'}" />
                    <TextBlock Grid.Column="1" Text="{Binding Metrics.GpuClock, StringFormat=GPU CLOCK: {0:0} MHz}" Foreground="{Binding Theme.ForegroundColor, FallbackValue=#FFFFFF}" Opacity="0.85" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right" FontFamily="{Binding Theme.FontFamily, FallbackValue='Segoe UI'}" />
                </Grid>
            </Grid>

            <!-- Screen 2: SSDs. Constrain in a fixed grid area preserving equal gap top and bottom -->
            <Grid x:Name="SsdScreen" Grid.ColumnSpan="2" Visibility="Hidden" Opacity="0">
                <!-- TOP LOGO Area (Same as Gauges) -->
                <Image Source="{Binding Theme.LogoPath}" Height="160" Margin="20,-20,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" Stretch="Uniform" />

                <ItemsControl ItemsSource="{Binding Metrics.Drives}" AlternationCount="2" Margin="0,120,0,85">
                    <!-- Use an ItemsPanel of Grid so we can absolutely align Top/Bottom independently -->
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Grid/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <!-- Bottom SSD card remains locked in its absolute position relative to bottom edge of grid -->
                            <Setter Property="VerticalAlignment" Value="Bottom"/>
                            <Setter Property="Margin" Value="10,0,10,0"/>
                            
                            <Style.Triggers>
                                <!-- Top SSD card (Index 0) is pushed to top edge of grid -->
                                <Trigger Property="ItemsControl.AlternationIndex" Value="0">
                                    <Setter Property="VerticalAlignment" Value="Top"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Thicker left border to catch direct stark lighting, thin elsewhere -->
                            <Border BorderThickness="2,0.5,0.5,0.5" CornerRadius="12" Height="300">
                                <!-- Intense Left-Edge Highlight simulating strong directional lighting -->
                                <Border.BorderBrush>
                                    <!-- Angled from middle-left (0,0.5) sweeping right -->
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                        <!-- Stark bright white on the left edge only -->
                                        <GradientStop Color="#767676" Offset="0"/>
                                        <GradientStop Color="#4A4A4A" Offset="0.1"/>
                                        <GradientStop Color="#111111" Offset="0.15"/>
                                        <GradientStop Color="#090909" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>

                                <!-- Matte Gradient Background (Lighting from Top-Left to Bottom-Right) -->
                                <Border.Background>
                                    <!-- Angled from top-left (0,0) to bottom-right (1,1) -->
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1A1A1A" Offset="0"/>
                                        <GradientStop Color="#121212" Offset="0.2"/>
                                        <GradientStop Color="#080808" Offset="0.8"/>
                                        <GradientStop Color="#050505" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>

                                <Border.Effect>
                                    <!-- Shadow pulling downwards but tighter to give it weight -->
                                    <DropShadowEffect Color="Black" Direction="270" BlurRadius="20" ShadowDepth="10" Opacity="0.8"/>
                                </Border.Effect>

                                <Grid>
                                    <!-- "Screw" details on Left Edge (Subtle) -->
                                    <!--<Ellipse Width="10" Height="10" Fill="#060606" Stroke="#111111" StrokeThickness="0.5" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="14, 28, 0, 0" />-->
                                    <!--<Ellipse Width="10" Height="10" Fill="#060606" Stroke="#111111" StrokeThickness="0.5" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="14, 0, 0, 28" />-->

                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,10,0,0">
                                        <!-- VENDOR -->
                                        <TextBlock Text="{Binding Vendor}" Foreground="{Binding DataContext.Theme.ForegroundColor, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="32" FontWeight="Heavy" HorizontalAlignment="Center" FontFamily="{Binding DataContext.Theme.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"/>

                                        <!-- MODEL & SIZE -->
                                        <TextBlock Text="{Binding Model}" Foreground="{Binding DataContext.Theme.ForegroundColor, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="15" FontWeight="Normal" HorizontalAlignment="Center" Margin="0,2,0,0" FontFamily="{Binding DataContext.Theme.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        <TextBlock Text="{Binding SizeString}" Foreground="{Binding DataContext.Theme.ForegroundColor, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="12" FontWeight="Normal" Opacity="0.75" HorizontalAlignment="Center" Margin="0,4,0,5" FontFamily="{Binding DataContext.Theme.FontFamily, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    </StackPanel>
                                    
                                    <!-- Red square accent at bottom center -->
                                    <Rectangle Width="50" Height="50" Fill="#E63946" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,0" />

                                    <!-- Right Arrow -->
                                    <Path Fill="{Binding DataContext.Theme.ForegroundColor, RelativeSource={RelativeSource AncestorType=Window}}" Data="M 0,0 L 9,6 L 0,15 Z" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <!-- Screen 3: Hero Plugin Screen. Shows one plugin at a time in rotation. -->
            <Grid x:Name="PluginScreen" Grid.ColumnSpan="2" Visibility="Hidden" Opacity="0">
                <Image Source="{Binding Theme.LogoPath}" Height="160" Margin="20,-20,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" Stretch="Uniform" />
                
                <ContentControl x:Name="PluginHost" Margin="0,100,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            </Grid>

            <!-- Screen 4: Built-in Clock Screen -->
            <Grid x:Name="ClockScreen" Grid.ColumnSpan="2" Visibility="Hidden" Opacity="0">
                <controls:BuiltInClockScreen x:Name="BuiltInClock"/>
            </Grid>

        </Grid>
    </Viewbox>
</Window>
