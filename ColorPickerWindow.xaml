<Window x:Class="PcStatsMonitor.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Color" Height="520" Width="380"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Border Background="#D9111111" CornerRadius="15" BorderBrush="#33FFFFFF" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="SET THEME COLOR" Foreground="#88FFFFFF" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Grid.Row="1" Text="Basic Colors" Foreground="#AAAAAA" Margin="0,0,0,5"/>
            <ItemsControl x:Name="ColorGrid" Grid.Row="2" Margin="0,0,0,15">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="5"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Width="45" Height="45" Margin="5" Click="Color_Click" Tag="{Binding}" Background="{Binding}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" BorderBrush="#22FFFFFF" BorderThickness="1">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Grid.Row="3" Text="Custom Color" Foreground="#AAAAAA" Margin="0,10,0,5"/>
            <Grid Grid.Row="4" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="R:" Foreground="#AAA" Width="20" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtR" Width="35" DockPanel.Dock="Right" Background="#222" Foreground="#FFF" BorderThickness="0" TextAlignment="Center" TextChanged="Rgb_TextChanged"/>
                        <Slider x:Name="SldR" Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" Margin="5,0" ValueChanged="Slider_ValueChanged" VerticalAlignment="Center"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="G:" Foreground="#AAA" Width="20" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtG" Width="35" DockPanel.Dock="Right" Background="#222" Foreground="#FFF" BorderThickness="0" TextAlignment="Center" TextChanged="Rgb_TextChanged"/>
                        <Slider x:Name="SldG" Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" Margin="5,0" ValueChanged="Slider_ValueChanged" VerticalAlignment="Center"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="B:" Foreground="#AAA" Width="20" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtB" Width="35" DockPanel.Dock="Right" Background="#222" Foreground="#FFF" BorderThickness="0" TextAlignment="Center" TextChanged="Rgb_TextChanged"/>
                        <Slider x:Name="SldB" Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" Margin="5,0" ValueChanged="Slider_ValueChanged" VerticalAlignment="Center"/>
                    </DockPanel>
                    <DockPanel Margin="0,5,0,0">
                        <TextBlock Text="Hex:" Foreground="#AAA" Width="30" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtHex" Height="22" Background="#222" Foreground="#FFF" BorderThickness="0" Padding="5,2" TextChanged="TxtHex_TextChanged"/>
                    </DockPanel>
                </StackPanel>

                <Border Grid.Column="1" x:Name="PreviewBorder" CornerRadius="10" BorderBrush="#22FFFFFF" BorderThickness="1" Background="#FFFFFF">
                    <TextBlock x:Name="LblPreview" Text="Preview" Foreground="#88000000" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
            </Grid>

            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="CANCEL" Click="Cancel_Click" Background="Transparent" Foreground="#88FFFFFF" BorderThickness="0" Margin="0,0,15,0" Cursor="Hand"/>
                <Button Content="SELECT" Click="Select_Click" Width="80" Height="30" Background="#3b82f6" Foreground="White" FontWeight="Bold" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
