<Window x:Class="PcStatsMonitor.Controls.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notification" Height="220" Width="380"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Border CornerRadius="8" Background="#F0181818" BorderThickness="1" BorderBrush="#3b82f6" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.5" />
        </Border.Effect>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock x:Name="TxtTitle" Text="Notification" Foreground="#3b82f6" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
            <TextBlock x:Name="TxtMessage" Grid.Row="1" Text="Message" Foreground="#E0E0E0" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,15"/>
            
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" x:Name="ButtonPanel">
                <Button x:Name="BtnOk" Content="OK" Width="80" Height="30" Margin="10,0,0,0"
                        Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnOk_Click" Visibility="Collapsed">
                    <Button.Background>
                        <SolidColorBrush Color="#3b82f6" Opacity="0.8"/>
                    </Button.Background>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2563eb"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnYes" Content="Yes" Width="80" Height="30" Margin="10,0,0,0"
                        Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnYes_Click" Visibility="Collapsed">
                    <Button.Background>
                        <SolidColorBrush Color="#3b82f6" Opacity="0.8"/>
                    </Button.Background>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2563eb"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnNo" Content="No" Width="80" Height="30" Margin="10,0,0,0"
                        Foreground="#E0E0E0" BorderThickness="1" BorderBrush="#555555" Cursor="Hand" Click="BtnNo_Click" Visibility="Collapsed">
                    <Button.Background>
                        <SolidColorBrush Color="#222222" Opacity="0.8"/>
                    </Button.Background>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#333333"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Grid>
    </Border>
</Window>
