<UserControl x:Class="PcStatsMonitor.Controls.BuiltInClockScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             UseLayoutRounding="True" SnapsToDevicePixels="True"
             d:DesignHeight="854" d:DesignWidth="480">

    <Grid x:Name="RootClockGrid" Width="480" Height="854">

        <!-- Custom Background (shown when UseCustomBackground = true) -->
        <Border x:Name="CustomBgBlock" Visibility="Collapsed">
            <Grid>
                <Rectangle x:Name="CustomBgColor" Fill="#060606"/>
                <Image x:Name="CustomBgImage" Stretch="UniformToFill" Opacity="1"/>
            </Grid>
        </Border>

             <!-- Main Content -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="160"/>   <!-- Space for Logo (handled by MainWindow) -->
                <RowDefinition Height="*"/>      <!-- Analog Clock -->
                <RowDefinition Height="Auto"/>   <!-- Digital + Date -->
                <RowDefinition Height="80"/>     <!-- Bottom padding -->
            </Grid.RowDefinitions>

            <!-- Logo Area - binds to Window DataContext, same as Gauges screen -->
            <Image x:Name="LogoImage" Grid.Row="0"
                   Source="{Binding DataContext.Theme.LogoPath, RelativeSource={RelativeSource AncestorType=Window}}"
                   Height="160" Margin="20,-20,0,0"
                   VerticalAlignment="Top" HorizontalAlignment="Center"
                   Stretch="Uniform"/>
            <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid x:Name="ClockContainer" RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="ClockScale" ScaleX="1" ScaleY="1"/>
                            <TranslateTransform x:Name="ClockTranslate" X="0" Y="0"/>
                        </TransformGroup>
                    </Grid.RenderTransform>

                    <!-- Outer Glow Ring (face-specific, set in code) -->
                    <Ellipse x:Name="OuterRing" Width="300" Height="300"/>

                    <!-- Clock Face Background (ellipse for circular, rect for square faces) -->
                    <Ellipse x:Name="ClockFaceEllipse" Width="280" Height="280" Fill="#1A1A1A"/>
                    <Rectangle x:Name="ClockFaceRect" Width="280" Height="280" Fill="#1A1A1A" RadiusX="12" RadiusY="12" Visibility="Collapsed"/>

                    <!-- Minute Tick Marks (60 ticks drawn in code-behind) -->
                    <Canvas x:Name="TickCanvas" Width="280" Height="280"/>

                    <!-- Hands Canvas -->
                    <Canvas Width="280" Height="280">
                        <!-- Hour Hand -->
                        <Rectangle x:Name="HandHour"
                                   Canvas.Left="137.5" Canvas.Top="75"
                                   Width="5" Height="65"
                                   Fill="White" RadiusX="3" RadiusY="3"
                                   RenderTransformOrigin="0.5,1">
                            <Rectangle.RenderTransform>
                                <RotateTransform x:Name="RotHour" Angle="0"/>
                            </Rectangle.RenderTransform>
                        </Rectangle>

                        <!-- Minute Hand -->
                        <Rectangle x:Name="HandMin"
                                   Canvas.Left="138" Canvas.Top="50"
                                   Width="4" Height="90"
                                   Fill="White" RadiusX="2" RadiusY="2"
                                   RenderTransformOrigin="0.5,1">
                            <Rectangle.RenderTransform>
                                <RotateTransform x:Name="RotMin" Angle="0"/>
                            </Rectangle.RenderTransform>
                        </Rectangle>

                        <!-- Second Hand -->
                        <Rectangle x:Name="HandSec"
                                   Canvas.Left="139" Canvas.Top="30"
                                   Width="2" Height="110"
                                   Fill="#3b82f6" RadiusX="1" RadiusY="1"
                                   RenderTransformOrigin="0.5,1">
                            <Rectangle.RenderTransform>
                                <RotateTransform x:Name="RotSec" Angle="0"/>
                            </Rectangle.RenderTransform>
                        </Rectangle>

                        <!-- Tail of second hand (counterweight) -->
                        <Rectangle x:Name="HandSecTail"
                                   Canvas.Left="139" Canvas.Top="140"
                                   Width="2" Height="25"
                                   Fill="#3b82f6" RadiusX="1" RadiusY="1"
                                   RenderTransformOrigin="0.5,0">
                            <Rectangle.RenderTransform>
                                <RotateTransform x:Name="RotSecTail" Angle="0"/>
                            </Rectangle.RenderTransform>
                        </Rectangle>

                        <!-- Center Pin -->
                        <Ellipse x:Name="CenterPin"
                                 Canvas.Left="133" Canvas.Top="133"
                                 Width="14" Height="14"
                                 Fill="#3b82f6"/>
                    </Canvas>
                </Grid>
            </Grid>

            <!-- ─── Digital Time ──────────────────────────────────────────── -->
            <StackPanel x:Name="PnlDigitalClock" Grid.Row="2" HorizontalAlignment="Center">
                <StackPanel.RenderTransform>
                    <TranslateTransform x:Name="DigitalTranslate" X="0" Y="0"/>
                </StackPanel.RenderTransform>

                <Grid HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtDigital"
                               Text="12:00"
                               Foreground="White"
                               FontSize="80"
                               FontWeight="SemiBold"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtAmPm"
                               Text="AM"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,16,-48,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Top"/>
                </Grid>

                <TextBlock x:Name="TxtDate"
                           Text="Monday, 17 Mar 2026"
                           Foreground="#AAAAAA"
                           FontSize="18"
                           FontFamily="Segoe UI"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,-8,0,0">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="DateTranslate" X="0" Y="0"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </StackPanel>

        </Grid>
    </Grid>
</UserControl>
