<UserControl x:Class="PcStatsMonitor.Controls.CircularSlider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="150" Height="150"
             Background="Transparent"
             MouseDown="OnMouseDown" MouseMove="OnMouseMove" MouseUp="OnMouseUp">
    <Viewbox>
        <Grid Width="200" Height="200">
            <!-- Background Arc -->
            <Path Stroke="#333333" StrokeThickness="15" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Margin="0">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="50.5,149.5">
                            <ArcSegment Point="149.5,149.5" Size="70,70" SweepDirection="Clockwise" IsLargeArc="True"/>
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>

            <!-- Active Arc -->
            <Path x:Name="ActiveArc" Stroke="#d97746" StrokeThickness="15" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Margin="0">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure x:Name="ActiveArcFigure" StartPoint="50.5,149.5">
                            <ArcSegment x:Name="ActiveArcSegment" Point="149.5,149.5" Size="70,70" SweepDirection="Clockwise" IsLargeArc="True"/>
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>

            <!-- Thumb -->
            <Canvas>
                <Ellipse x:Name="Thumb" Width="20" Height="20" Fill="White" Stroke="#333" StrokeThickness="1" Canvas.Left="120" Canvas.Top="130">
                    <Ellipse.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.5"/>
                    </Ellipse.Effect>
                </Ellipse>
            </Canvas>

            <!-- Text Content -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="TxtTitle" Foreground="#999" FontSize="14" HorizontalAlignment="Center" Text="Fan Speed"/>
                <TextBlock x:Name="TxtValue" Foreground="White" FontSize="36" FontWeight="Light" HorizontalAlignment="Center" Text="50%"/>
            </StackPanel>
        </Grid>
    </Viewbox>
</UserControl>
