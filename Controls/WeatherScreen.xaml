<UserControl x:Class="PcStatsMonitor.Controls.WeatherScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="854" d:DesignWidth="480">

    <UserControl.Resources>
        <SolidColorBrush x:Name="ForecastCardBackground" x:Key="ForecastCardBackground" Color="#14888888"/>
        <SolidColorBrush x:Name="ForecastTabActiveForeground" x:Key="ForecastTabActiveForeground" Color="White"/>
        <!-- Weather icons are now global in App.xaml -->

        <Style x:Key="ForecastTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,28,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="Transparent" Padding="0,0,0,8">
                            <ContentPresenter x:Name="Presenter" Content="{TemplateBinding Content}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Presenter" Property="TextBlock.Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Presenter" Property="TextBlock.Foreground" Value="LightGray"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootWeatherGrid" Width="480" Height="854">
        <!-- Main Background and Theme Support -->
        <Border x:Name="WeatherBg" Background="#121212">
            <!-- Reduced top margin (140) and bottom margin (10) to make room for graph -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Hero/Stats/Tabs with Margins -->
                    <RowDefinition Height="*"/>    <!-- Graph (Full Width) -->
                </Grid.RowDefinitions>
 
                <!-- Part A: Margined Content -->
                <Grid Grid.Row="0" Margin="24,110,24,0" ClipToBounds="False">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Hero Card -->
                        <RowDefinition Height="Auto"/> <!-- Stats Bar -->
                        <RowDefinition Height="Auto"/> <!-- Tabs -->
                        <RowDefinition Height="Auto"/> <!-- Forecast List -->
                    </Grid.RowDefinitions>
 
                    <!-- 1. Hero Card -->
                    <Border x:Name="HeroCard" Grid.Row="0" Background="#1E1E1E" CornerRadius="28" Padding="24" Margin="0,0,0,12">
                        <Grid>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="TxtCity" Text="NEW YORK" Foreground="{StaticResource BrandBlue}" FontSize="12" FontWeight="Bold" Margin="0,0,0,2"/>
                                <TextBlock x:Name="TxtDateHeader" Text="14 August 2024" Foreground="#888888" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtCondition" Text="Cloudy" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock x:Name="TxtTemp" Text="18°C" Foreground="White" FontSize="64" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                            
                            <Border HorizontalAlignment="Right" VerticalAlignment="Center" Width="160" Height="160">
                                <Image x:Name="ImgMainWeather" Stretch="Uniform"/>
                            </Border>
                        </Grid>
                    </Border>
 
                    <!-- 2. Stats Bar -->
                    <Border Grid.Row="1" Background="#1A888888" CornerRadius="28" Padding="16,20" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center" Opacity="0.9">
                                <Path x:Name="IconWind" Data="{StaticResource WindLines}" Fill="#888888" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock x:Name="TxtWind" Text="10 km/h" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="Wind" Foreground="#888888" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center" Opacity="0.9">
                                <Path x:Name="IconHumidity" Data="{StaticResource HumidityIcon}" Fill="#888888" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock x:Name="TxtHumidity" Text="98%" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="Humidity" Foreground="#888888" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
 
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center" Opacity="0.9">
                                <Path x:Name="IconPressure" Data="{StaticResource PressureIcon}" Fill="#888888" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock x:Name="TxtPressure" Text="1013 hPa" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="Pressure" Foreground="#888888" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
 
                    <!-- 3. Tabs -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5,0,0">
                        <RadioButton x:Name="TabToday" Content="Today" IsChecked="True" Style="{StaticResource ForecastTabStyle}" Checked="ForecastTab_Checked"/>
                        <RadioButton x:Name="TabTomorrow" Content="Tomorrow" Margin="25,0,0,0" Style="{StaticResource ForecastTabStyle}" Checked="ForecastTab_Checked"/>
                        <RadioButton x:Name="TabNextDays" Content="Next 4 Days" Margin="25,0,0,0" Style="{StaticResource ForecastTabStyle}" Checked="ForecastTab_Checked"/>
                    </StackPanel>
 
                    <!-- 4. Forecast List -->
                    <ItemsControl x:Name="LstForecast" Grid.Row="3" Margin="0,10,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{Binding CardBrush}" CornerRadius="16" Margin="4" Padding="12,12">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Day}" Foreground="{Binding DayBrush}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <Border Width="28" Height="28" Margin="0,6">
                                            <Image Source="{Binding IconImage}" Stretch="Uniform"/>
                                        </Border>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Temp}" Foreground="{Binding TempBrush}" FontSize="16" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding TempLow}" Foreground="#888888" FontSize="14" FontWeight="SemiBold" Margin="4,2,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
 
                <!-- Part B: Full Width Graph — Increased overall spacing to prevent clipping -->
                <StackPanel Grid.Row="1" VerticalAlignment="Bottom" Margin="0,15,0,25">
                    <TextBlock Text="TEMPERATURE TREND" Foreground="#666666" FontSize="11" FontWeight="Bold" Margin="24,0,0,42"/>
                    <Grid Height="140" Margin="0,5,0,0" ClipToBounds="False">
                        <Path x:Name="GraphFillPath" Opacity="0.1">
                            <Path.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#88FFFFFF" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Path.Fill>
                        </Path>
                        <Path x:Name="GraphPath" Stroke="#55FFFFFF" StrokeThickness="3.5" StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
                        
                        <Grid x:Name="GraphPointContainer" Width="16" Height="16" HorizontalAlignment="Left" VerticalAlignment="Top">
                            <Ellipse Width="10" Height="10" Fill="#121212" Stroke="White" StrokeThickness="2.5"/>
                        </Grid>
 
                        <Grid x:Name="GraphTooltip" HorizontalAlignment="Left" VerticalAlignment="Top" Opacity="0">
                            <Border x:Name="TooltipBox" Background="White" CornerRadius="8" Padding="10,6" MinWidth="50" Margin="0,0,0,5" HorizontalAlignment="Left">
                                <StackPanel>
                                    <TextBlock x:Name="TxtTooltipTime" FontSize="10" Foreground="#AA000000" HorizontalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtTooltipTemp" FontSize="15" Foreground="Black" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Path x:Name="TooltipArrow" Data="M 0,0 L 6,6 L 12,0 Z" Fill="White" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                        </Grid>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Indicator -->
        <Border x:Name="LoadingOverlay" VerticalAlignment="Top" Height="3" Background="#33FFFFFF" Visibility="Collapsed">
            <ProgressBar IsIndeterminate="True" Height="3" BorderThickness="0" Background="Transparent" Foreground="#3b82f6"/>
        </Border>
    </Grid>
</UserControl>
