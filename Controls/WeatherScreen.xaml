<UserControl x:Class="PcStatsMonitor.Controls.WeatherScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="854" d:DesignWidth="480">

    <UserControl.Resources>
        <SolidColorBrush x:Name="ForecastCardBackground" x:Key="ForecastCardBackground" Color="#14888888"/>
        <SolidColorBrush x:Name="ForecastTabActiveForeground" x:Key="ForecastTabActiveForeground" Color="White"/>
        <!-- Vector Icons (iPhone Style) -->
        <PathGeometry x:Key="SunIcon" Figures="M 25,10 A 15,15 0 1 1 25,40 A 15,15 0 1 1 25,10 Z M 25,5 V 2 M 25,48 V 45 M 45,25 H 48 M 2,25 H 5 M 39,11 L 41,9 M 9,41 L 11,39 M 39,39 L 41,41 M 9,9 L 11,11"/>
        <PathGeometry x:Key="MoonIcon" Figures="M 35,15 A 15,15 0 1 0 15,35 A 12,12 0 1 1 35,15 Z"/>
        <PathGeometry x:Key="CloudIcon" Figures="M 10,35 Q 5,35 5,30 Q 5,23 12,22 Q 13,10 25,10 Q 35,10 38,18 Q 45,18 45,26 Q 45,35 37,35 Z"/>
        <PathGeometry x:Key="SmallCloudIcon" Figures="M 25,40 Q 22,40 22,37 Q 22,33 26,32 Q 27,26 33,26 Q 38,26 40,30 Q 44,30 44,34 Q 44,40 40,40 Z"/>
        <PathGeometry x:Key="RainDrops" Figures="M 15,38 L 15,45 M 25,38 L 25,45 M 35,38 L 35,45"/>
        <PathGeometry x:Key="Snowflakes" Figures="M 15,40 A 1.5,1.5 0 1 1 15,37 Z M 21,43 A 1.5,1.5 0 1 1 21,40 Z M 27,40 A 1.5,1.5 0 1 1 27,37 Z M 33,43 A 1.5,1.5 0 1 1 33,40 Z M 39,40 A 1.5,1.5 0 1 1 39,37 Z"/>
        <PathGeometry x:Key="HazeLines" Figures="M 10,20 H 40 M 7,26 H 43 M 10,32 H 40"/>
        <PathGeometry x:Key="HumidityIcon" Figures="M 25,10 C 25,10 15,22 15,30 A 10,10 0 0 0 35,30 C 35,22 25,10 25,10 Z M 21,28 A 1.5,1.5 0 1 1 19,31 A 1.5,1.5 0 0 1 21,28 Z M 27,34 A 1.5,1.5 0 1 1 25,37 A 1.5,1.5 0 0 1 27,34 Z M 20,38 L 30,26"/>
        <PathGeometry x:Key="PressureIcon" Figures="M 15,5 V 15 M 15,15 L 12,12 M 15,15 L 18,12 M 22,5 V 15 M 22,15 L 19,12 M 22,15 L 25,12 M 29,5 V 15 M 29,15 L 26,12 M 29,15 L 32,12 M 36,5 V 15 M 36,15 L 33,12 M 36,15 L 39,12 M 5,22 Q 15,18 25,22 T 45,22 M 5,28 Q 15,24 25,28 T 45,28 M 5,34 Q 15,30 25,34 T 45,34"/>
        <PathGeometry x:Key="FogLines" Figures="M 5,38 H 45 M 5,42 H 45 M 5,46 H 45"/>
        <PathGeometry x:Key="LightningIcon" Figures="M 25,35 L 20,45 L 30,45 L 25,55"/>
        <PathGeometry x:Key="HailPellets" Figures="M 18,38 A 2,2 0 1 1 18,34 Z M 32,38 A 2,2 0 1 1 32,34 Z M 25,44 A 2,2 0 1 1 25,40 Z"/>
        <PathGeometry x:Key="WindLines" Figures="M 5,20 Q 20,10 35,20 T 45,20 M 5,25 Q 20,15 35,25 T 45,25 M 5,30 Q 20,20 35,30 T 45,30"/>
        <PathGeometry x:Key="TornadoFunnel" Figures="M 10,10 H 40 L 30,50 Q 25,55 20,50 L 10,10 Z M 15,20 H 35 M 20,35 H 30"/>

        <Style x:Key="ForecastTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,28,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="Transparent" Padding="0,0,0,8">
                            <ContentPresenter x:Name="Presenter" Content="{TemplateBinding Content}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Presenter" Property="TextBlock.Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Presenter" Property="TextBlock.Foreground" Value="LightGray"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootWeatherGrid" Width="480" Height="854">
        <!-- Main Background and Theme Support -->
        <Border x:Name="WeatherBg" Background="#121212">
            <!-- Increased top margin (165) to ensure branding logo (160 height) doesn't overlap text -->
            <Grid Margin="24,165,24,24" ClipToBounds="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Hero Card (Date, Condition, Temp, Icon) -->
                    <RowDefinition Height="Auto"/> <!-- Stats Bar (Wind, Humidity, Rain) -->
                    <RowDefinition Height="*"/>    <!-- Forecast & Graph Area -->
                </Grid.RowDefinitions>

                <!-- 1. Hero Card -->
                <Border x:Name="HeroCard" Grid.Row="0" Background="#1E1E1E" CornerRadius="28" Padding="28" Margin="0,0,0,16">
                    <Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="TxtDateHeader" Text="14 August 2024" Foreground="#888888" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtCondition" Text="Cloudy" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtTemp" Text="18°C" Foreground="White" FontSize="64" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                        
                        <!-- Large Multi-Color Icon (Composition) -->
                        <Grid HorizontalAlignment="Right" VerticalAlignment="Center" Width="120" Height="120">
                            <!-- Layer 1: Sun / Moon -->
                            <Path x:Name="PathWeatherIconBack" Data="{StaticResource SunIcon}" Fill="#FFA500" Width="80" Height="80" Stretch="Uniform" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,10,0"/>
                            <!-- Layer 2: Cloud -->
                            <Path x:Name="PathWeatherIconCloud" Data="{StaticResource CloudIcon}" Fill="White" Width="100" Height="100" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <!-- Layer 3: Rain / Lightning / Haze / Snow -->
                            <Path x:Name="PathWeatherIconFront" Data="{StaticResource RainDrops}" Fill="#3498db" Width="100" Height="100" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>


                <!-- 2. Stats Bar -->
                <Border Grid.Row="1" Background="#1A888888" CornerRadius="28" Padding="16,24" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Wind -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" Opacity="0.9">
                            <Path x:Name="IconWind" Data="{StaticResource WindLines}" Fill="#888888" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtWind" Text="10 km/h" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Wind" Foreground="#888888" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        
                        <!-- Humidity -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center" Opacity="0.9">
                            <Path x:Name="IconHumidity" Data="{StaticResource HumidityIcon}" Fill="#888888" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtHumidity" Text="98%" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Humidity" Foreground="#888888" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Pressure -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" Opacity="0.9">
                            <Path x:Name="IconPressure" Data="{StaticResource PressureIcon}" Fill="#888888" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtPressure" Text="1013 hPa" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Pressure" Foreground="#888888" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 3. Forecast & Graph Area -->
                <Grid Grid.Row="2" Margin="0,8,0,0">
                    <StackPanel>
                        <!-- Tabs -->
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="TabToday" Content="Today" IsChecked="True" Style="{StaticResource ForecastTabStyle}" Checked="ForecastTab_Checked"/>
                            <RadioButton x:Name="TabTomorrow" Content="Tomorrow" Margin="25,0,0,0" Style="{StaticResource ForecastTabStyle}" Checked="ForecastTab_Checked"/>
                            <RadioButton x:Name="TabNextDays" Content="Next 4 Days" Margin="25,0,0,0" Style="{StaticResource ForecastTabStyle}" Checked="ForecastTab_Checked"/>
                        </StackPanel>

                        <!-- Forecast Items -->
                        <ItemsControl x:Name="LstForecast" Margin="0,25,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1AFFFFFF" CornerRadius="16" Margin="4" Padding="12,15">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Day}" Foreground="#88FFFFFF" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <Grid Width="32" Height="32" Margin="0,10">
                                                <Path Data="{Binding BackIcon}" Fill="{Binding BackFill}" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,2,0"/>
                                                <Path Data="{Binding CloudIcon}" Fill="{Binding CloudFill}" Width="28" Height="28" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <Path Data="{Binding FrontIcon}" Fill="{Binding FrontFill}" Width="28" Height="28" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                            <TextBlock Text="{Binding Temp}" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Graph Area -->
                        <Grid Height="120" Margin="0,30,0,0" ClipToBounds="False">
                            <!-- Area under the graph -->
                            <Path x:Name="GraphFillPath" Opacity="0.15">
                                <Path.Fill>
                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                        <GradientStop Color="White" Offset="0"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </Path.Fill>
                            </Path>

                            <!-- The wavy line -->
                            <Path x:Name="GraphPath" Stroke="#55FFFFFF" StrokeThickness="3" StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
                            
                            <!-- Focus point (Ring Style) -->
                            <Grid x:Name="GraphPointContainer" Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                                <Ellipse Fill="White" Opacity="0.3"/>
                                <Ellipse Width="6" Height="6" Fill="#121212" Stroke="White" StrokeThickness="2"/>
                            </Grid>

                            <!-- Speech Bubble Tooltip -->
                            <Grid x:Name="GraphTooltip" HorizontalAlignment="Right" VerticalAlignment="Bottom" Opacity="0">
                                <Border Background="White" CornerRadius="8" Padding="8,4" MinWidth="40">
                                    <StackPanel>
                                        <TextBlock x:Name="TxtTooltipTime" FontSize="10" Foreground="#88000000" HorizontalAlignment="Center" FontWeight="Bold"/>
                                        <TextBlock x:Name="TxtTooltipTemp" FontSize="14" Foreground="Black" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <!-- Tip of bubble -->
                                <Path Data="M 0,0 L 5,5 L 10,0 Z" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-5"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Loading Indicator -->
        <Border x:Name="LoadingOverlay" VerticalAlignment="Top" Height="3" Background="#33FFFFFF" Visibility="Collapsed">
            <ProgressBar IsIndeterminate="True" Height="3" BorderThickness="0" Background="Transparent" Foreground="#3b82f6"/>
        </Border>
    </Grid>
</UserControl>
