<UserControl x:Class="PcStatsMonitor.Controls.WeatherScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="854" d:DesignWidth="480">

    <Grid x:Name="RootWeatherGrid" Width="480" Height="854">
        <!-- Optional Custom Background (Managed by Applied Theme) -->
        <Border x:Name="CustomBgBlock" Visibility="Collapsed">
            <Image x:Name="ImgBg" Stretch="UniformToFill" Opacity="0.5"/>
        </Border>

        <Grid Margin="12,100,12,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- City + Date -->
                <RowDefinition Height="*"/>      <!-- Current Weather Hero -->
                <RowDefinition Height="Auto"/>   <!-- Detail Grid (Humidity, Wind, etc) -->
                <RowDefinition Height="Auto"/>   <!-- Forecast Row -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,30">
                <TextBlock x:Name="TxtCity" Text="LOADING..." Foreground="White" FontSize="36" FontWeight="Heavy" HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#000" Opacity="0.5"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock x:Name="TxtDate" Text="Checking for updates..." Foreground="#BBFFFFFF" FontSize="14" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Current Weather Hero (Glassmorphism Card) -->
            <Viewbox Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="0,5">
                <Border Background="#1AFFFFFF" CornerRadius="30" Padding="40,30" BorderBrush="#33FFFFFF" BorderThickness="1" Width="440">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="40" ShadowDepth="15" Opacity="0.3" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <!-- Weather Icon -->
                            <TextBlock x:Name="TxtWeatherIcon" Text="☀️" Foreground="White" FontSize="100" VerticalAlignment="Center" Margin="0,0,20,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="TxtTemp" Text="--" Foreground="White" FontSize="90" FontWeight="Bold" Margin="0,-10,0,0"/>
                                <TextBlock x:Name="TxtCondition" Text="Condition" Foreground="#CCFFFFFF" FontSize="18" FontWeight="SemiBold" Margin="5,-10,0,0" TextAlignment="Left" TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                            <TextBlock Text="H:" Foreground="#CCFFFFFF" FontSize="16" Margin="0,0,5,0"/>
                            <TextBlock x:Name="TxtHigh" Text="--" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,15,0"/>
                            <TextBlock Text="L:" Foreground="#CCFFFFFF" FontSize="16" Margin="0,0,5,0"/>
                            <TextBlock x:Name="TxtLow" Text="--" Foreground="White" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Viewbox>

            <!-- Detail Grid -->
            <UniformGrid Grid.Row="2" Columns="2" Margin="0,20,0,20">
                <!-- Humidity -->
                <Border Margin="5" Background="#0FFFFFFF" CornerRadius="15" Padding="15" BorderBrush="#1AFFFFFF" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="HUMIDITY" Foreground="#88FFFFFF" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="TxtHumidity" Text="--" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <!-- Wind -->
                <Border Margin="5" Background="#0FFFFFFF" CornerRadius="15" Padding="15" BorderBrush="#1AFFFFFF" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="WIND SPEED" Foreground="#88FFFFFF" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="TxtWind" Text="--" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <!-- UV Index or Pressure -->
                <Border Margin="5" Background="#0FFFFFFF" CornerRadius="15" Padding="15" BorderBrush="#1AFFFFFF" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="PRESSURE" Foreground="#88FFFFFF" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="TxtPressure" Text="--" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <!-- Feels Like -->
                <Border Margin="5" Background="#0FFFFFFF" CornerRadius="15" Padding="15" BorderBrush="#1AFFFFFF" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="FEELS LIKE" Foreground="#88FFFFFF" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="TxtFeelsLike" Text="--" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Forecast Row -->
            <Border Grid.Row="3" Background="#0FFFFFFF" CornerRadius="20" Padding="10,15" BorderBrush="#1AFFFFFF" BorderThickness="1" Margin="5,0">
                <StackPanel>
                    <TextBlock Text="5-DAY FORECAST" Foreground="#88FFFFFF" FontSize="10" FontWeight="Bold" Margin="5,0,0,15"/>
                    <ItemsControl x:Name="LstForecast">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><UniformGrid Columns="5"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Day}" Foreground="#AAFFFFFF" FontSize="12" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Icon}" Foreground="White" FontSize="24" HorizontalAlignment="Center" Margin="0,8"/>
                                    <TextBlock Text="{Binding Temp}" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Subtle Loading Indicator (Non-blocking) -->
        <Border x:Name="LoadingOverlay" VerticalAlignment="Top" Height="3" Background="#33FFFFFF" Visibility="Collapsed">
            <ProgressBar IsIndeterminate="True" Height="3" BorderThickness="0" Background="Transparent" Foreground="#3b82f6"/>
        </Border>
    </Grid>
</UserControl>
