<Window x:Class="PcStatsMonitor.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BYLD Core - Settings" Height="500" Width="480" WindowStartupLocation="CenterScreen" 
        WindowStyle="None" AllowsTransparency="True" Background="#D9222222" ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#E0E0E0"/>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,10,0,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ToolTip" Value="Click to edit"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,8,0,8"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TabPanel Grid.Row="0" IsItemsHost="True" Background="Transparent" Margin="0,0,0,10"/>
                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Padding="15,6" Margin="0,0,4,0" CornerRadius="6" Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="Background" Value="#40FFFFFF"/>
                            </MultiTrigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="#AAAAAA"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#333333" BorderThickness="1" CornerRadius="8">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="BYLD Core Settings" FontWeight="Bold" FontSize="16" Margin="0"/>
                <Button Content="✕" Width="30" Height="25" HorizontalAlignment="Right" Background="Transparent" Foreground="#888888" FontWeight="Bold" Click="BtnClose_Click"/>
            </Grid>

            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
                <!-- THEME AND COLORS -->
                <TabItem Header="Colors">
                    <StackPanel Margin="10,20,10,10">
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Background Color:" VerticalAlignment="Center" Margin="0"/>
                            <Button x:Name="BtnBgColor" Grid.Column="1" Width="100" Height="25" Click="BtnColorPick_Click" BorderBrush="#888" BorderThickness="1"/>
                        </Grid>
                        
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Foreground (Text) Color:" VerticalAlignment="Center" Margin="0"/>
                            <Button x:Name="BtnFgColor" Grid.Column="1" Width="100" Height="25" Click="BtnColorPick_Click" BorderBrush="#888" BorderThickness="1"/>
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Accent (Glowing Ring) Color:" VerticalAlignment="Center" Margin="0"/>
                            <Button x:Name="BtnAccentColor" Grid.Column="1" Width="100" Height="25" Click="BtnColorPick_Click" BorderBrush="#888" BorderThickness="1"/>
                        </Grid>
                        
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Track (Unused Ring) Color:" VerticalAlignment="Center" Margin="0"/>
                            <Button x:Name="BtnTrackColor" Grid.Column="1" Width="100" Height="25" Click="BtnColorPick_Click" BorderBrush="#888" BorderThickness="1"/>
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Alert (Warnings) Color:" VerticalAlignment="Center" Margin="0"/>
                            <Button x:Name="BtnAlertColor" Grid.Column="1" Width="100" Height="25" Click="BtnColorPick_Click" BorderBrush="#888" BorderThickness="1"/>
                        </Grid>
                    </StackPanel>
                </TabItem>

                <!-- LAYOUT -->
                <TabItem Header="Layout">
                    <Grid Margin="10,20,10,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Toggle Monitors:" Margin="0,0,0,10" Foreground="#AAAAAA"/>
                            <CheckBox x:Name="ChkCpu" Content="CPU Monitor" Click="OnSettingChanged"/>
                            <CheckBox x:Name="ChkGpu" Content="GPU Monitor" Click="OnSettingChanged"/>
                            <CheckBox x:Name="ChkMemory" Content="Memory Monitor" Click="OnSettingChanged"/>
                            <CheckBox x:Name="ChkMotherboard" Content="Motherboard Monitor" Click="OnSettingChanged"/>
                            <CheckBox x:Name="ChkNetwork" Content="Network Stats" Click="OnSettingChanged"/>
                            
                            <TextBlock Text="Active Screens:" Margin="0,15,0,10" Foreground="#AAAAAA"/>
                            <CheckBox x:Name="ChkGaugesScreen" Content="Gauges Dashboard" Click="OnScreenSettingChanged"/>
                            <CheckBox x:Name="ChkStorageScreen" Content="Storage Dashboard" Click="OnScreenSettingChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Monitor Ordering:" Margin="0,0,0,10" Foreground="#AAAAAA"/>
                            <ListBox x:Name="LstOrder" Background="#222" Foreground="#FFF" Height="150" Margin="0,0,0,10" BorderThickness="0" SelectionMode="Single">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Margin="5,2" Foreground="#EEE"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="Move Up" Margin="0,0,5,0" Click="BtnMoveUp_Click"/>
                                <Button Grid.Column="1" Content="Move Down" Margin="5,0,0,0" Click="BtnMoveDown_Click"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- IMAGES -->
                <TabItem Header="Images">
                    <Grid Margin="10,20,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Custom Logo Image:"/>
                        <Grid Grid.Row="1" Margin="0,0,0,15">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtLogo" IsReadOnly="True" Margin="0,0,5,0"/>
                            <Button Grid.Column="1" Content="Browse..." Width="80" Click="BtnBrowseLogo_Click" Margin="0,0,5,0"/>
                            <Button Grid.Column="2" Content="Clear" Width="50" Click="BtnClearLogo_Click"/>
                        </Grid>

                        <TextBlock Grid.Row="2" Text="Custom Background Image:"/>
                        <Grid Grid.Row="3" Margin="0,0,0,15">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtBgImage" IsReadOnly="True" Margin="0,0,5,0"/>
                            <Button Grid.Column="1" Content="Browse..." Width="80" Click="BtnBrowseBg_Click" Margin="0,0,5,0"/>
                            <Button Grid.Column="2" Content="Clear" Width="50" Click="BtnClearBg_Click"/>
                        </Grid>
                        
                        <TextBlock Grid.Row="4" Text="Background Image Opacity:" Margin="0,10,0,5"/>
                        <Slider x:Name="SldOpacity" Grid.Row="5" Minimum="0.0" Maximum="1.0" TickFrequency="0.1" ValueChanged="SldOpacity_ValueChanged"/>
                    </Grid>
                </TabItem>
            </TabControl>
            
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Save Settings" Width="110" Padding="8,6" Background="#4A90E2" Click="BtnSave_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
