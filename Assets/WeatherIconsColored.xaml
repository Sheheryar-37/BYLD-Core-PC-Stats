<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Modular Components (Base Shapes) - Unified 100x100 Grid -->
    <PathGeometry x:Key="BaseCloud" Figures="M 25,60 C 10,60 10,40 25,40 C 25,20 45,20 50,30 C 60,20 80,30 75,50 C 90,50 90,70 75,70 L 25,70 Z"/>
    <Geometry x:Key="BaseSun">M 50,20 A 30,30 0 1 1 50,80 A 30,30 0 1 1 50,20 M 50,5 V 15 M 50,85 V 95 M 5,50 H 15 M 85,50 H 95 M 18,18 L 25,25 M 75,75 L 82,82 M 75,25 L 82,18 M 18,82 L 25,75</Geometry>
    <Geometry x:Key="BaseMoon">M 50,20 A 30,30 0 1 1 50,80 A 40,40 0 0 0 50,20</Geometry>
    <Geometry x:Key="BaseRainDrop">M 50,40 C 40,55 40,70 50,80 C 60,70 60,55 50,40</Geometry>
    <Geometry x:Key="BaseRainSlash">M 45,40 L 35,60</Geometry>
    <Geometry x:Key="BaseSnowflake">M 50,20 L 50,80 M 24,35 L 76,65 M 24,65 L 76,35 M 40,40 L 60,60 M 60,40 L 40,60</Geometry>
    <Geometry x:Key="BaseSnowDot">M 48,48 A 4,4 0 1 1 48,40 A 4,4 0 1 1 48,48</Geometry>
    <Geometry x:Key="BaseWindWavy">M 10,40 C 25,25 45,55 60,40 S 80,25 90,40 M 10,55 C 25,40 45,70 60,55 S 80,40 90,55</Geometry>
    <Geometry x:Key="BaseLightning">M 55,10 L 35,45 L 55,45 L 45,90 L 65,40 L 45,40 Z</Geometry>

