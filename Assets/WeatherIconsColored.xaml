    <!-- Icon 1: Simple Cloud -->
    <DrawingGroup x:Key="Icon_1_Cloud_Pure">
        <GeometryDrawing Brush="White" Geometry="{StaticResource BaseCloud}"/>
    </DrawingGroup>

    <!-- Icon 2: Double Cloud -->
    <DrawingGroup x:Key="Icon_2_Cloud_Double">
        <DrawingGroup>
            <DrawingGroup.Transform><TranslateTransform X="-15" Y="-10"/></DrawingGroup.Transform>
            <GeometryDrawing Brush="#DDE4E8" Geometry="{StaticResource BaseCloud}"/>
        </DrawingGroup>
        <GeometryDrawing Brush="White" Geometry="{StaticResource BaseCloud}"/>
    </DrawingGroup>

    <!-- Icon 3: Pure Sun -->
    <DrawingGroup x:Key="Icon_3_Sun_Pure">
        <GeometryDrawing Brush="#FFD700" Geometry="{StaticResource BaseSun}"/>
    </DrawingGroup>

    <!-- Icon 4: Sun Low/Setting -->
    <DrawingGroup x:Key="Icon_4_Sun_Low">
        <DrawingGroup>
            <DrawingGroup.Transform><TranslateTransform Y="25"/></DrawingGroup.Transform>
            <GeometryDrawing Brush="#FFA500" Geometry="{StaticResource BaseSun}"/>
        </DrawingGroup>
    </DrawingGroup>

    <!-- Icon 5: Pure Moon -->
    <DrawingGroup x:Key="Icon_5_Moon_Pure">
        <GeometryDrawing Brush="#3498DB" Geometry="{StaticResource BaseMoon}"/>
    </DrawingGroup>

    <!-- Icon 6: Moon + Cloud (Night Partly Cloudy) -->
    <DrawingGroup x:Key="Icon_6_Moon_Cloud">
        <DrawingGroup>
            <DrawingGroup.Transform>
                <TransformGroup>
                    <ScaleTransform ScaleX="0.6" ScaleY="0.6" CenterX="50" CenterY="50"/>
                    <TranslateTransform X="15" Y="-15"/>
                </TransformGroup>
            </DrawingGroup.Transform>
            <GeometryDrawing Brush="#3498DB" Geometry="{StaticResource BaseMoon}"/>
        </DrawingGroup>
        <GeometryDrawing Brush="White" Geometry="{StaticResource BaseCloud}"/>
    </DrawingGroup>

